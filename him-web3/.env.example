# HIM web3 — keep secrets SERVER-SIDE only (never import into React)
# Copy to .env and fill in. .env is gitignored.

PORT=8787
HOST=127.0.0.1

# RPC providers (server only)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# or Infura:
# ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY

# Optional chain id (1 = mainnet, 11155111 = sepolia)
CHAIN_ID=1

# Optional: block public CORS in production
# CORS_ORIGIN=http://localhost:5173
