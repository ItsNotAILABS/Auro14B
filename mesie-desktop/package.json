{
  "name": "mesie-desktop",
  "version": "0.4.0",
  "description": "MESIE Spectral Intelligence Engine — Desktop Application",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "author": "Alfredo Medina <alfredo@itsnotailabs.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "electron-store": "^11.0.0"
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.mesie.desktop",
    "productName": "MESIE Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/icon.png"
    }
  }
}
