    "layers": 24,
    "attention_heads": 16,
    "kv_heads": 4,
    "intermediate_size": 5632,
    "activation": "silu",
    "normalization": "rmsnorm",
    "position_encoding": "rope",
    "context_window_tokens_target": 8192,
    "vocab_size_target": 128000
