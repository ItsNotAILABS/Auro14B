  "subagent_roles": ["router", "tool_call", "embed_fast", "spectral_triage"],
  "can_embed_subagents": false,
  "purpose": "edge and on-device sub-agent lane — fast routing, tool calls, spectral triage",
  "required_receipts": ["tokenizer", "data_mixture", "pretrain_or_adaptation", "evaluation", "serving"]
