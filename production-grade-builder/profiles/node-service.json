{
  "kind": "node-service",
  "description": "Node.js service or package",
  "required_artifacts": [
    "README.md",
    "PACKET_POLICY.md",
    "manifest.json",
    "release_manifest.json",
    "reports/build_report.json",
    "scores/quality_score.json",
    "tools/quality_gate.py",
    "src/index.js",
    "package.json"
  ],
  "optional_artifacts": [
    "Dockerfile",
    "tests/index.test.js",
    ".eslintrc.json"
  ],
  "template_vars": {
    "entry_point": "src/index.js",
    "build_cmd": "npm install",
    "serve_cmd": "node src/index.js"
  }
}
